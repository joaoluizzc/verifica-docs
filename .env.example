DB_URL=jdbc:postgresql://localhost:5432/verificadocs
DB_USERNAME=postgres
DB_PASSWORD=postgres
OCR_SPACE_ENABLED=true
OCR_SPACE_API_KEY=sua_chave_ocr_space
UPLOAD_DIR=uploads
SERVER_PORT=8080

# Login com Google, opcional.
# Crie uma credencial OAuth 2.0 do tipo Web no Google Cloud.
# Redirect URI local: http://localhost:8080/login/oauth2/code/google
# GOOGLE_CLIENT_ID=seu_client_id_google
# GOOGLE_CLIENT_SECRET=seu_client_secret_google

# Use local para testar sem PostgreSQL, com H2 em memoria.
spring.profiles.active=local
